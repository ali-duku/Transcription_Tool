          "default": null,
          "title": "Guide Answer Images"
        },
        "set_up_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Set Up Text"
        },
        "related_question": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Related Question"
        },
        "question_type": {
          "type": "string",
          "const": "multiple_choice",
          "default": "multiple_choice",
          "title": "Question Type"
        },
        "choices": {
          "type": "array",
          "title": "Choices",
          "items": {
            "$ref": "#/$defs/MultipleChoiceOption"
          }
        },
        "value": {
          "type": "integer",
          "title": "Value"
        }
      },
      "required": [
        "id",
        "question_text",
        "guide_answer",
        "choices",
        "value"
      ]
