{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./transcription_schema.json",
  "title": "Transcript",
  "type": "object",
  "properties": {
    "textbook_page": {
      "type": "integer",
      "title": "Textbook Page"
    },
    "textbook_pdf_page": {
      "type": "integer",
      "title": "Textbook Pdf Page"
    },
    "guidebook_pdf_pages": {
      "anyOf": [
        {
          "$ref": "#/$defs/PageRange"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Guidebook Pdf Pages"
    },
    "page_type": {
      "$ref": "#/$defs/PageType"
    },
    "lesson_preamble": {
      "anyOf": [
        {
          "$ref": "#/$defs/LessonPreamble"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lesson Preamble"
    },
    "instructional_content": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InstructionalContent"
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Instructional Content"
    },
    "practice_questions": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/PracticeQuestionFreeForm"
              },
              {
                "$ref": "#/$defs/PracticeQuestionMultipleChoice"
              },
              {
                "$ref": "#/$defs/PracticeQuestionCheckbox"
              },
              {
                "$ref": "#/$defs/PracticeQuestionFillInTheBlanks"
              },
              {
                "$ref": "#/$defs/PracticeQuestionAnnotate"
              },
              {
                "$ref": "#/$defs/PracticeQuestionMatching"
              },
              {
                "$ref": "#/$defs/PracticeQuestionCreateTable"
              }
            ]
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Practice Questions"
    }
  },
  "required": [
    "textbook_page",
    "textbook_pdf_page",
    "page_type"
  ],
  "$defs": {
    "PageRange": {
      "type": "array",
      "title": "PageRange",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "integer",
          "title": "Start"
        },
        {
          "type": "integer",
          "title": "End"
        }
      ]
    },
    "Point": {
      "type": "array",
      "title": "Point",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "integer",
          "title": "X"
        },
        {
          "type": "integer",
          "title": "Y"
        }
      ]
    },
    "Bbox": {
      "type": "array",
      "title": "Bbox",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "$ref": "#/$defs/Point",
          "title": "Topright"
        },
        {
          "$ref": "#/$defs/Point",
          "title": "Bottomleft"
        }
      ]
    },
    "PagedBbox": {
      "type": "object",
      "title": "PagedBbox",
      "properties": {
        "page": {
          "type": "integer",
          "title": "Page"
        },
        "position": {
          "$ref": "#/$defs/Bbox"
        }
      },
      "required": [
        "page",
        "position"
      ]
    },
    "PageType": {
      "type": "string",
      "title": "PageType",
      "enum": [
        "content",
        "table_of_content",
        "unit_table_of_content",
        "vocabulary",
        "project",
        "other"
      ]
    },
    "LessonPreamble": {
      "type": "object",
      "title": "LessonPreamble",
      "properties": {
        "title": {
          "type": "string",
          "title": "Title"
        },
        "lesson_standards": {
          "type": "array",
          "title": "Lesson Standards",
          "items": {
            "type": "string"
          }
        },
        "terminology": {
          "type": "array",
          "title": "Terminology",
          "items": {
            "type": "string"
          }
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        }
      },
      "required": [
        "title",
        "lesson_standards",
        "terminology"
      ]
    },
    "InstructionalContent": {
      "type": "object",
      "title": "InstructionalContent",
      "properties": {
        "section_title": {
          "type": "string",
          "title": "Section Title"
        },
        "text": {
          "type": "string",
          "title": "Text"
        },
        "images": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PagedBbox"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Images"
        }
      },
      "required": [
        "section_title",
        "text"
      ]
    },
    "MultipleChoiceOption": {
      "type": "object",
      "title": "MultipleChoiceOption",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "text": {
          "type": "string",
          "title": "Text"
        }
      },
      "required": [
        "text"
      ]
    },
    "PracticeQuestionFreeForm": {
      "type": "object",
      "title": "PracticeQuestionFreeForm",
      "properties": {
        "id": {
          "type": "string",
          "title": "Id"
        },
        "question_text": {
          "type": "string",
          "title": "Question Text"
        },
        "question_images": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PagedBbox"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Question Images"
        },
        "guide_answer": {
          "type": "string",
          "title": "Guide Answer"
        },
        "guide_pdf_page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Guide Pdf Page"
        },
        "guide_answer_images": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PagedBbox"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Guide Answer Images"
        },
        "set_up_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Set Up Text"
        },
        "related_question": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Related Question"
        },
        "question_type": {
          "type": "string",
          "const": "free_form",
          "default": "free_form",
          "title": "Question Type"
        }
      },
      "required": [
        "id",
        "question_text",
        "guide_answer"
      ]
    },
    "PracticeQuestionMultipleChoice": {
      "type": "object",
      "title": "PracticeQuestionMultipleChoice",
